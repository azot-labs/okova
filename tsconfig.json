{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "rootDir": ".",
    "types": ["node"],
    "noUncheckedSideEffectImports": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "paths": {
      "@": ["./src/extension"],
      "@/*": ["./src/extension/*"],
      "~": ["./src/extension"],
      "~/*": ["./src/extension/*"],
      "@@": ["."],
      "@@/*": ["./*"],
      "~~": ["."],
      "~~/*": ["./*"],
      "@okova/lib": ["./src/lib"],
      "@okova/lib/*": ["./src/lib/*"]
    }
  },
  "include": ["src", "test", "*.config.ts", ".wxt/wxt.d.ts"],
  "exclude": ["dist", ".output", "node_modules"]
}
